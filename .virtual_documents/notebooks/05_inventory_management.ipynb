def simulate_inventory(daily_demand_series, eoq, rop, safety_stock, lead_time, initial_stock=None):
    """
    Simple continuous-review (s, Q) inventory simulation.
    Order EOQ units whenever stock falls to or below ROP.
    Order arrives after `lead_time` days.
    """
    if initial_stock is None:
        initial_stock = eoq + safety_stock  # start fully stocked

    stock     = initial_stock
    inventory = []
    orders    = {}   # {day_of_arrival: qty}
    order_trigger_days = []
    stockout_days      = []

    for day, demand in enumerate(daily_demand_series):
        # Receive any pending orders
        if day in orders:
            stock += orders[day]

        # Satisfy demand
        if stock >= demand:
            stock -= demand
        else:
            stockout_days.append(day)
            stock = 0  # stockout — demand unfulfilled

        # Check ROP — place order if not one already in transit
        arrival_day = day + lead_time
        if stock <= rop and arrival_day not in orders:
            orders[arrival_day] = eoq
            order_trigger_days.append(day)

        inventory.append(stock)

    return np.array(inventory), order_trigger_days, stockout_days


