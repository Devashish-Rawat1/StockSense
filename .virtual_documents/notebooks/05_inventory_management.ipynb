abc = item_stats[['item','annual_forecast_demand']].sort_values('annual_forecast_demand', ascending=False).copy()
abc['cumulative_pct'] = abc['annual_forecast_demand'].cumsum() / abc['annual_forecast_demand'].sum() * 100

def abc_class(cumulative_pct):
    if cumulative_pct <= 70: return 'A'
    elif cumulative_pct <= 90: return 'B'
    else: return 'C'

abc['ABC_class'] = abc['cumulative_pct'].apply(abc_class)

# Merge back
inventory_policy = inventory_policy.merge(
    abc[['item','ABC_class']],
    left_on='Item', right_on='item', how='left'
).drop(columns='item')

