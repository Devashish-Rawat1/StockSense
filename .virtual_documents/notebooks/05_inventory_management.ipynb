    annual_actual_demand   = ('sales',  'sum'),
    annual_forecast_demand = ('y_pred', 'sum'),
    avg_daily_demand       = ('y_pred', 'mean'),
    std_daily_demand       = ('y_pred', 'std'),    # demand variability
